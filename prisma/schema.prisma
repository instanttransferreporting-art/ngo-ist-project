generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  EMPLOYEE
}

enum TaskType {
  PREDEFINED
  EXTRA
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LockMode {
  FREE
  LOCKED
  HIDDEN
}

enum SheetTemplate {
  A
  B
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                    String   @id @default(cuid())
  name                  String
  email                 String   @unique
  password              String
  role                  Role     @default(EMPLOYEE)
  templatePreference    SheetTemplate?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  assignments     TaskAssignment[]
  dailyLogs       DailyTaskLog[]
  leaveRequests   LeaveRequest[]
  monthlySheets   MonthlySheet[]
  monthlyPlans    MonthlyAssignmentPlan[]
}

model TaskLibrary {
  id          String   @id @default(cuid())
  group       String
  title       String
  deadline    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  assignments     TaskAssignment[]
  dailyLogs       DailyTaskLog[]
  monthlyPlanTasks MonthlyPlanTask[]
}

model TaskAssignment {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  task TaskLibrary @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
}

/// Logs for both predefined tasks (taskId set) and extra tasks (taskId null).
/// For predefined tasks the (userId, taskId, date) triple is unique.
/// Extra tasks only need (userId, date, id) — multiple extras allowed per day.
model DailyTaskLog {
  id         String   @id @default(cuid())
  userId     String
  taskId     String?
  date       DateTime @db.Date
  done       Boolean  @default(false)
  type       TaskType @default(PREDEFINED)
  extraLabel String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  task TaskLibrary? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@unique([userId, taskId, date])
  @@index([userId, date])
}

model LeaveRequest {
  id        String      @id @default(cuid())
  userId    String
  startDate DateTime    @db.Date
  endDate   DateTime    @db.Date
  reason    String?
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Singleton record (id = "global") — tracks the current lock mode for day editing.
model DayLockConfig {
  id        String   @id @default("global")
  mode      LockMode @default(FREE)
  template  SheetTemplate @default(A)
  updatedAt DateTime @updatedAt
}

/// Singleton record (id = "global") — stores email configuration for cron jobs.
model EmailConfig {
  id               String   @id @default("global")
  recipients       String[] @default([])
  reminderRecipients String[] @default([])
  dailyRecipients  String[] @default([])
  monthlyRecipients String[] @default([])
  cc               String[] @default([])
  reminderBody     String   @default("Il vous reste {pendingCount} tâche(s) à compléter pour aujourd'hui.")
  reportBody       String   @default("Rapport journalier du {date}")
  monthlyReportBody String @default("Rapport mensuel")
  updatedAt        DateTime @updatedAt
}

/// Created once per (employee, month, year) the first time the sheet is opened.
model MonthlySheet {
  id        String   @id @default(cuid())
  userId    String
  month     Int
  year      Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

/// Pre-planned task assignments for a future month.
/// useCurrentTasks=true means "apply current TaskAssignment when month starts".
/// useCurrentTasks=false means use the tasks listed in MonthlyPlanTask.
model MonthlyAssignmentPlan {
  id              String   @id @default(cuid())
  userId          String
  month           Int
  year            Int
  useCurrentTasks Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks MonthlyPlanTask[]

  @@unique([userId, month, year])
}

model MonthlyPlanTask {
  id      String @id @default(cuid())
  planId  String
  taskId  String
  order   Int    @default(0)

  plan MonthlyAssignmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  task TaskLibrary           @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([planId, taskId])
}
